<!-- File: ClipHistory/MainWindow.xaml -->
<Window x:Class="ClipHistory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClipHistory" Height="500" Width="420"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 検索ボックス（上部） -->
        <TextBox x:Name="SearchBox" Grid.Row="0" Margin="0,0,0,6"
                 Padding="4" FontSize="13"
                 TextChanged="SearchBox_TextChanged"/>

        <!-- 仮想化リスト -->
        <ListBox x:Name="HistoryList" Grid.Row="1"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Item"
                 ScrollViewer.CanContentScroll="True"
                 AllowDrop="True"
                 MouseDoubleClick="HistoryList_MouseDoubleClick"
                 PreviewMouseLeftButtonDown="HistoryList_PreviewMouseLeftButtonDown"
                 MouseMove="HistoryList_MouseMove"
                 Drop="HistoryList_Drop"
                 DragOver="HistoryList_DragOver">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="★" Foreground="Goldenrod"
                                   Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding Text}"
                                   TextTrimming="CharacterEllipsis"
                                   ToolTip="{Binding Text}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="再コピー" Click="MenuCopy_Click"/>
                    <MenuItem Header="編集" Click="MenuEdit_Click"/>
                    <MenuItem Header="お気に入り登録/解除" Click="MenuFavorite_Click"/>
                    <MenuItem Header="削除" Click="MenuDelete_Click"/>
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>
    </Grid>
</Window>
