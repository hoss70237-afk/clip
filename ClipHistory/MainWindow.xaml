<!-- File: ClipHistory/MainWindow.xaml -->
<Window x:Class="ClipHistory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="500" Width="400"
        WindowStyle="None"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="White"
        BorderBrush="#999"
        BorderThickness="1"
        ShowInTaskbar="False"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display"
        Deactivated="Window_Deactivated">
    <WindowChrome.WindowChrome>
        <!-- タイトルバーなしでリサイズ枠のみ確保 -->
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0"/>
    </WindowChrome.WindowChrome>
    
    <Grid Margin="6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,6">
            <RadioButton x:Name="TabHistory" Content="履歴" GroupName="ModeTabs" IsChecked="True" Checked="Tab_Checked" Margin="0,0,10,0"/>
            <RadioButton x:Name="TabTemplate" Content="定型文" GroupName="ModeTabs" Checked="Tab_Checked"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="0,0,0,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <!-- 履歴用検索ボックス -->
            <TextBox x:Name="SearchBox" Grid.Column="0" Padding="4" FontSize="13" TextChanged="SearchBox_TextChanged"/>
            <Button x:Name="BtnClearSearch" Grid.Column="1" Content="✕" Width="26" Margin="4,0,0,0" ToolTip="クリア" Click="ClearSearch_Click"/>

            <!-- 定型文用セット選択ボックス（初期非表示） -->
            <ComboBox x:Name="ComboTemplateSet" Grid.Column="0" Padding="4" FontSize="13" Visibility="Collapsed" SelectionChanged="ComboTemplateSet_SelectionChanged" DisplayMemberPath="Name"/>
            <Button x:Name="BtnDeleteSet" Grid.Column="1" Content="✕" Width="26" Margin="4,0,0,0" ToolTip="このセットを削除" Click="DeleteSet_Click" Visibility="Collapsed"/>
        </Grid>

        <!-- 横スクロール無効化 + 複数選択・スクロールイベント追加 -->
        <ListBox x:Name="HistoryList" Grid.Row="2"
                 SelectionMode="Extended"
                 ScrollViewer.ScrollChanged="HistoryList_ScrollChanged"
                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                 VirtualizingPanel.IsVirtualizing="True"
                 VirtualizingPanel.VirtualizationMode="Recycling"
                 VirtualizingPanel.ScrollUnit="Item"
                 ScrollViewer.CanContentScroll="True"
                 AllowDrop="True"
                 PreviewMouseLeftButtonDown="HistoryList_PreviewMouseLeftButtonDown"
                 PreviewMouseLeftButtonUp="HistoryList_PreviewMouseLeftButtonUp"
                 MouseMove="HistoryList_MouseMove"
                 Drop="HistoryList_Drop"
                 DragOver="HistoryList_DragOver"
                 ContextMenuOpening="HistoryList_ContextMenuOpening">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="★" Foreground="Goldenrod" Margin="0,0,4,0" VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Grid.Column="1" Text="{Binding DisplayText}" TextTrimming="CharacterEllipsis" ToolTip="{Binding FullText}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
            <ListBox.ContextMenu>
                <ContextMenu x:Name="DynamicMenu"/>
            </ListBox.ContextMenu>
        </ListBox>
    </Grid>
</Window>
